# Copy to .env (which git ignores) and fill in.

# How the collector reaches the lab: ssh -J $UCL_GATEWAY -l $UCL_USER host.$UCL_DOMAIN
UCL_GATEWAY=
UCL_USER=
UCL_DOMAIN=

# Optional. Set it and every cycle also seals data/vault.json — the real
# usernames and the full command lines — which the page can open in the browser
# when a reader types this passphrase into "unlock names".
#
# The sealed file is published to a public repo, so it can be attacked offline
# at leisure: use a long passphrase, not a word. Leave this blank and no vault
# is written and no unlock button appears.
UCL_UNLOCK_KEY=

# Optional: interpreter used by scripts/publish.sh (default python3).
LEADERBOARD_PYTHON=
